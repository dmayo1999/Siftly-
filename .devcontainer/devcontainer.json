{
  "name": "Siftly Codespace",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "prisma.prisma"
      ]
    }
  },
  "forwardPorts": [3000],
  "postCreateCommand": "npm install && cp .env.example .env && npx prisma db push",
  "remoteUser": "node"
}
